{
  "name": "@picsa/enketo-webform",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/enketo-webform.umd.cjs",
  "module": "./dist/enketo-webform.js",
  "types": "./dist/enketo-webform.d.ts",
  "exports": {
    ".": {
      "types": "./dist/enketo-webform.d.ts",
      "import": "./dist/enketo-webform.js",
      "require": "./dist/enketo-webform.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "demo"
  ],
  "scripts": {
    "start": "concurrently -c \"cyan,magenta\" -n \"LIB,DEMO\" \"bun run dev:lib\" \"bun run dev:demo\"",
    "dev:lib": "vite build --watch",
    "dev:demo": "bun run --cwd demo dev",
    "lint": "bun run eslint --max-warnings=-1; bun run prettier --check .",
    "format": "bun run eslint --fix; bun run prettier --write .",
    "prepare": "husky",
    "build": "bun run build:types && bun run build:lib && bun run build:demo",
    "build:types": "custom-elements-manifest analyze --config custom-elements-manifest.config.mjs",
    "build:lib": "vite build",
    "build:demo": "cd demo && bun run build && cd ../",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "bootstrap-datepicker": "^1.10.1",
    "fast-xml-parser": "^5.7.2",
    "form-data": "^4.0.5",
    "html5sortable": "^0.14.0",
    "jquery": "^4.0.0",
    "jquery-touchswipe": "^1.6.19",
    "lit": "^3.3.2",
    "mergexml": "^1.2.4",
    "signature_pad": "^5.1.3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@custom-elements-manifest/to-markdown": "^0.1.0",
    "@eslint/js": "^10.0.1",
    "@types/jquery": "^4.0.0",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^2.0.5",
    "@wc-toolkit/jsx-types": "^1.5.2",
    "concurrently": "^9.2.1",
    "custom-elements-manifest": "^2.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.77.8",
    "typedoc": "^0.26.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "customElements": "custom-elements.json"
}
