{
  "name": "enketo-webform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
  ],
"scripts": {
    "dev": "bun run demo:dev",
    "start": "bun run demo:dev",
    "build": "bun run packages:build && bun run demo:build",
    "preview": "bun run demo:preview",
    "test": "vitest",
    "test:run": "vitest run",
    "packages:build": "cd packages/enketo-webform && bun run build",
    "demo:dev": "cd demo && bun run dev",
    "demo:build": "cd demo && bun run build",
    "demo:preview": "cd demo && bun run preview",
    "docs": "cd packages/enketo-webform && bun run docs:cem && bun run scripts/docs-to-markdown.mjs"
  },
  "dependencies": {
    "bootstrap-datepicker": "^1.10.1",
    "enketo-core": "^6.1.3",
    "fast-xml-parser": "^4.4.1",
    "form-data": "^4.0.0",
    "html5sortable": "^0.14.0",
    "jquery": "^4.0.0",
    "jquery-touchswipe": "^1.6.19",
    "lit": "^3.3.2",
    "mergexml": "^1.2.4",
    "signature_pad": "^5.1.3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@custom-elements-manifest/to-markdown": "^0.1.0",
    "@types/jquery": "^4.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "custom-elements-manifest": "^2.1.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "sass": "^1.77.8",
    "typedoc": "^0.26.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.5"
  }
}
