{
  "name": "@picsa/enketo-webform",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/enketo-webform.umd.cjs",
  "module": "./dist/enketo-webform.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/enketo-webform.js",
      "require": "./dist/enketo-webform.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./types/preact": "./types/preact.d.ts",
    "./types/react": "./types/react.d.ts"
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "docs:cem": "custom-elements-manifest analyze --litelement --globs \"src/enketo-webform.ts\" \"src/utils.ts\" \"src/kobo-service.ts\" --outdir ../../docs"
  },
  "dependencies": {
    "enketo-core": "^6.1.3",
    "fast-xml-parser": "^4.4.1",
    "form-data": "^4.0.0",
    "html5sortable": "^0.10.0",
    "jquery": "^4.0.0",
    "jquery-touchswipe": "^1.6.19",
    "lit": "^3.3.2",
    "mergexml": "^1.2.4"
  },
  "devDependencies": {},
  "customElements": "custom-elements.json"
}
